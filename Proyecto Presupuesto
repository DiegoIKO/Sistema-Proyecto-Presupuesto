  const [editingId, setEditingId] = useState(null);
  const [datasetName, setDatasetName] = useState("Escenario Base 2027");
  const [filters, setFilters] = useState({
    subdireccion: "__all__",
    asignacion: "__all__",
    subtitulo: "__all__",
    programa: "__all__",
    instrumento: "__all__",
    financiamiento: "__all__",
  });

  useEffect(() => {
    const saved = localStorage.getItem(STORAGE_KEY);
    if (saved) {
      const parsed = JSON.parse(saved);
      setRows(parsed.rows || initialData);
      setDatasetName(parsed.datasetName || "Escenario Base 2027");
    }
  }, []);

  useEffect(() => {
    localStorage.setItem(STORAGE_KEY, JSON.stringify({ rows, datasetName }));
  }, [rows, datasetName]);

  const options = useMemo(() => ({
    subdireccion: [...new Set(rows.map((r) => r.subdireccion).filter(Boolean))],
    asignacion: [...new Set(rows.map((r) => r.asignacion).filter(Boolean))],
    subtitulo: [...new Set(rows.map((r) => r.subtitulo).filter(Boolean))],
    programa: [...new Set(rows.map((r) => r.programa).filter(Boolean))],
    instrumento: [...new Set(rows.map((r) => r.instrumento).filter(Boolean))],
    financiamiento: [...new Set(rows.map((r) => r.financiamiento).filter(Boolean))],
  }), [rows]);

  const filteredRows = useMemo(() => {
    return rows.filter((row) =>
      Object.entries(filters).every(([key, value]) => value === "__all__" || row[key] === value)
    ).filter((row) => {
      if (!searchText.trim()) return true;
      const text = searchText.toLowerCase();
      return [row.subdireccion, row.asignacion, row.subtitulo, row.programa, row.instrumento, row.financiamiento, row.prioridad, row.observacion]
        .filter(Boolean)
        .some((v) => String(v).toLowerCase().includes(text));
    });
  }, [rows, filters, searchText]);

  const totals = useMemo(() => {
    const total2026 = sum(filteredRows, "monto2026");
    const total2027 = sum(filteredRows, "monto2027");
    const proyectos2026 = sum(filteredRows, "proyectos2026");
    const proyectos2027 = sum(filteredRows, "proyectos2027");
    const vigente2027 = sum(filteredRows, "presupuestoVigente2027");
    const comprometido2027 = sum(filteredRows, "presupuestoComprometido2027");
    const devengado2027 = sum(filteredRows, "presupuestoDevengado2027");
    const pagado2027 = sum(filteredRows, "presupuestoPagado2027");
    const beneficiarios2027 = sum(filteredRows, "beneficiarios2027");
    const inflacionPromedio = safeDiv(filteredRows.reduce((acc, item) => acc + Number(item.inflacionPct || 0), 0), filteredRows.length || 1);
    const variacionAbs = total2027 - total2026;
    const variacionPct = total2026 ? (variacionAbs / total2026) * 100 : 0;
    const variacionRealPct = ((1 + variacionPct / 100) / (1 + inflacionPromedio / 100) - 1) * 100;
    return {
      total2026,
      total2027,
      proyectos2026,
      proyectos2027,
      vigente2027,
      comprometido2027,
      devengado2027,
      pagado2027,
      beneficiarios2027,
      inflacionPromedio,
      variacionAbs,
      variacionPct,
      variacionRealPct,
      promedio2026: safeDiv(total2026, proyectos2026),
      promedio2027: safeDiv(total2027, proyectos2027),
      montoPorBeneficiario2027: safeDiv(total2027, beneficiarios2027),
      variacionProyectos: proyectos2027 - proyectos2026,
      top3Share: topShare(filteredRows),
      ejecucionPct: vigente2027 ? (devengado2027 / vigente2027) * 100 : 0,
      pagoPct: vigente2027 ? (pagado2027 / vigente2027) * 100 : 0,
      compromisoPct: vigente2027 ? (comprometido2027 / vigente2027) * 100 : 0,
    };
  }, [filteredRows]);

  const bySubdireccion = useMemo(() => groupByField(filteredRows, "subdireccion"), [filteredRows]);
  const bySubtitulo = useMemo(() => groupByField(filteredRows, "subtitulo"), [filteredRows]);
  const byPrograma = useMemo(() => groupByField(filteredRows, "programa"), [filteredRows]);
  const byInstrumento = useMemo(() => groupByField(filteredRows, "instrumento"), [filteredRows]);
  const byFinanciamiento = useMemo(() => groupByField(filteredRows, "financiamiento"), [filteredRows]);
  const byAsignacion = useMemo(() => groupByField(filteredRows, "asignacion"), [filteredRows]);

  const rankingMontos = useMemo(() => [...byAsignacion].sort((a, b) => b.monto2027 - a.monto2027).slice(0, 8), [byAsignacion]);
  const rankingVariacion = useMemo(() => [...byAsignacion].sort((a, b) => b.variacionAbs - a.variacionAbs).slice(0, 8), [byAsignacion]);
  const decrecimientos = useMemo(() => [...byAsignacion].filter((x) => x.variacionAbs < 0).sort((a, b) => a.variacionAbs - b.variacionAbs).slice(0, 5), [byAsignacion]);

  const outlierThreshold = useMemo(() => calculateOutlierThreshold(filteredRows), [filteredRows]);
  const outliers = useMemo(() => filteredRows.filter((r) => Number(r.monto2027) > outlierThreshold), [filteredRows, outlierThreshold]);

  const insights = useMemo(() => {
    const maxSubdireccion = [...bySubdireccion].sort((a, b) => b.monto2027 - a.monto2027)[0];
    const maxGrowth = [...byInstrumento].sort((a, b) => b.variacionPct - a.variacionPct)[0];
    const maxDrop = [...byInstrumento].sort((a, b) => a.variacionPct - b.variacionPct)[0];
    const messages = [];

    messages.push(`El presupuesto total ${totals.variacionAbs >= 0 ? "aumenta" : "disminuye"} en ${formatPct(totals.variacionPct)} entre 2026 y 2027.`);
    if (maxSubdireccion) messages.push(`${maxSubdireccion.name} concentra el mayor monto 2027 con ${formatCLP(maxSubdireccion.monto2027)}.`);
    if (maxGrowth) messages.push(`${maxGrowth.name} presenta la mayor variación relativa positiva con ${formatPct(maxGrowth.variacionPct)}.`);
    if (maxDrop && maxDrop.variacionPct < 0) messages.push(`${maxDrop.name} muestra la mayor caída relativa con ${formatPct(maxDrop.variacionPct)}.`);
    messages.push(`El top 3 de asignaciones concentra ${formatPct(totals.top3Share)} del presupuesto 2027, útil para monitorear concentración.`);
    if (outliers.length > 0) messages.push(`Se detectan ${outliers.length} registros con montos 2027 excepcionalmente altos.`);

    return messages;
  }, [bySubdireccion, byInstrumento, totals, outliers]);

  function handleChange(key, value) {
    setForm((prev) => ({ ...prev, [key]: value }));
  }

  function resetForm() {
    setForm(blankForm);
    setEditingId(null);
  }

  function handleSubmit(e) {
    e.preventDefault();
    const payload = {
      id: editingId || crypto.randomUUID(),
      subdireccion: form.subdireccion.trim(),
      asignacion: form.asignacion.trim(),
      subtitulo: form.subtitulo.trim(),
      programa: form.programa.trim(),
      instrumento: form.instrumento.trim(),
      financiamiento: form.financiamiento.trim(),
      proyectos2026: Number(form.proyectos2026 || 0),
      proyectos2027: Number(form.proyectos2027 || 0),
      monto2026: Number(form.monto2026 || 0),
      monto2027: Number(form.monto2027 || 0),
      inflacionPct: Number(form.inflacionPct || 0),
      presupuestoVigente2027: Number(form.presupuestoVigente2027 || 0),
      presupuestoComprometido2027: Number(form.presupuestoComprometido2027 || 0),
      presupuestoDevengado2027: Number(form.presupuestoDevengado2027 || 0),
      presupuestoPagado2027: Number(form.presupuestoPagado2027 || 0),
      beneficiarios2027: Number(form.beneficiarios2027 || 0),
      prioridad: form.prioridad || "Media",
      observacion: form.observacion?.trim?.() || "",
    };

    const required = [payload.subdireccion, payload.asignacion, payload.subtitulo, payload.programa, payload.instrumento, payload.financiamiento];
    if (required.some((x) => !x)) return;

    if (editingId) {
      setRows((prev) => prev.map((row) => row.id === editingId ? payload : row));
    } else {
      setRows((prev) => [payload, ...prev]);
    }
    resetForm();
  }

