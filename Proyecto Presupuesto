          </div>
          <div className="grid grid-cols-1 gap-2 md:min-w-[280px]">
            <Label className="text-slate-200">Nombre del escenario</Label>
            <Input value={datasetName} onChange={(e) => setDatasetName(e.target.value)} className="border-white/20 bg-white/10 text-white placeholder:text-slate-300" />
          </div>
        </motion.div>

        <Tabs defaultValue="carga" className="space-y-6">
          <TabsList className="grid w-full grid-cols-2 rounded-2xl bg-slate-200 p-1">
            <TabsTrigger value="carga" className="rounded-2xl">Ingreso y administración</TabsTrigger>
            <TabsTrigger value="dashboard" className="rounded-2xl">Resultados ejecutivos</TabsTrigger>
          </TabsList>

          <TabsContent value="carga" className="space-y-6">
            <div className="grid gap-6 lg:grid-cols-[1.1fr_1.4fr]">
              <Card className="rounded-3xl shadow-sm">
                <CardHeader>
                  <CardTitle className="flex items-center gap-2 text-slate-800"><Plus className="h-5 w-5" /> {editingId ? "Editar registro" : "Nuevo registro"}</CardTitle>
                </CardHeader>
                <CardContent>
                  <form onSubmit={handleSubmit} className="grid grid-cols-1 gap-4 md:grid-cols-2">
                    {[
                      ["subdireccion", "Subdirección"],
                      ["asignacion", "Asignación presupuestaria"],
                      ["subtitulo", "Subtítulo"],
                      ["programa", "Programa Presupuestario"],
                      ["instrumento", "Instrumento"],
                      ["financiamiento", "Financiamiento"],
                    ].map(([key, label]) => (
                      <div key={key} className="space-y-2">
                        <Label>{label}</Label>
                        <Input value={form[key]} onChange={(e) => handleChange(key, e.target.value)} required />
                      </div>
                    ))}
                    {[
                      ["proyectos2026", "Cantidad de proyectos 2026"],
                      ["proyectos2027", "Cantidad de proyectos 2027"],
                      ["monto2026", "Monto 2026"],
                      ["monto2027", "Monto 2027"],
                    ].map(([key, label]) => (
                      <div key={key} className="space-y-2">
                        <Label>{label}</Label>
                        <Input type="number" min="0" step="1" value={form[key]} onChange={(e) => handleChange(key, e.target.value)} required />
                      </div>
                    ))}
                    <div className="md:col-span-2 flex flex-wrap gap-2 pt-2">
                      <Button type="submit" className="rounded-2xl">{editingId ? "Guardar cambios" : "Agregar registro"}</Button>
                      <Button type="button" variant="outline" onClick={resetForm} className="rounded-2xl">Limpiar</Button>
                      <Button type="button" variant="outline" onClick={() => downloadCSV(rows)} className="rounded-2xl"><Download className="mr-2 h-4 w-4" />Exportar CSV</Button>
                      <Button type="button" variant="destructive" onClick={resetData} className="rounded-2xl">Restablecer demo</Button>
                    </div>
                  </form>
                </CardContent>
              </Card>

              <Card className="rounded-3xl shadow-sm">
                <CardHeader>
                  <CardTitle className="flex items-center gap-2 text-slate-800"><FileText className="h-5 w-5" /> Registros cargados</CardTitle>
                </CardHeader>
                <CardContent className="space-y-4">
                  <div className="grid gap-3 md:grid-cols-3">
                    <div className="rounded-2xl bg-slate-100 p-4">
                      <p className="text-sm text-slate-500">Registros</p>
                      <p className="text-2xl font-semibold">{formatNumber(rows.length)}</p>
                    </div>
                    <div className="rounded-2xl bg-slate-100 p-4">
                      <p className="text-sm text-slate-500">Monto total 2027</p>
                      <p className="text-2xl font-semibold">{formatCLP(sum(rows, "monto2027"))}</p>
                    </div>
                    <div className="rounded-2xl bg-slate-100 p-4">
                      <p className="text-sm text-slate-500">Proyectos 2027</p>
                      <p className="text-2xl font-semibold">{formatNumber(sum(rows, "proyectos2027"))}</p>
                    </div>
                  </div>
                  <div className="max-h-[520px] overflow-auto rounded-2xl border">
                    <Table>
                      <TableHeader className="sticky top-0 bg-white">
                        <TableRow>
                          <TableHead>Subdirección</TableHead>
                          <TableHead>Asignación</TableHead>
                          <TableHead>Programa</TableHead>
                          <TableHead className="text-right">Monto 2027</TableHead>
                          <TableHead className="text-right">Acciones</TableHead>
                        </TableRow>
                      </TableHeader>
                      <TableBody>
                        {rows.map((row) => (
                          <TableRow key={row.id}>
                            <TableCell>{row.subdireccion}</TableCell>
                            <TableCell>{row.asignacion}</TableCell>
                            <TableCell>{row.programa}</TableCell>
                            <TableCell className="text-right">{formatCLP(row.monto2027)}</TableCell>
                            <TableCell className="text-right">
                              <div className="flex justify-end gap-2">
                                <Button size="icon" variant="outline" className="rounded-xl" onClick={() => handleEdit(row)}><Pencil className="h-4 w-4" /></Button>
                                <Button size="icon" variant="destructive" className="rounded-xl" onClick={() => handleDelete(row.id)}><Trash2 className="h-4 w-4" /></Button>
                              </div>
                            </TableCell>
                          </TableRow>
                        ))}
                      </TableBody>
                    </Table>
                  </div>
                </CardContent>
              </Card>
            </div>
          </TabsContent>

          <TabsContent value="dashboard" className="space-y-6">
            <Card className="rounded-3xl shadow-sm">
              <CardContent className="p-5">
                <div className="mb-4 flex items-center gap-2 text-slate-800"><Filter className="h-4 w-4" /><span className="font-medium">Filtros ejecutivos</span></div>
                <div className="grid gap-4 md:grid-cols-2 xl:grid-cols-6">
                  <FilterSelect label="Subdirección" value={filters.subdireccion} onChange={(v) => setFilters((p) => ({ ...p, subdireccion: v }))} options={options.subdireccion} />
                  <FilterSelect label="Asignación" value={filters.asignacion} onChange={(v) => setFilters((p) => ({ ...p, asignacion: v }))} options={options.asignacion} />
                  <FilterSelect label="Subtítulo" value={filters.subtitulo} onChange={(v) => setFilters((p) => ({ ...p, subtitulo: v }))} options={options.subtitulo} />
                  <FilterSelect label="Programa" value={filters.programa} onChange={(v) => setFilters((p) => ({ ...p, programa: v }))} options={options.programa} />
                  <FilterSelect label="Instrumento" value={filters.instrumento} onChange={(v) => setFilters((p) => ({ ...p, instrumento: v }))} options={options.instrumento} />
                  <FilterSelect label="Financiamiento" value={filters.financiamiento} onChange={(v) => setFilters((p) => ({ ...p, financiamiento: v }))} options={options.financiamiento} />
                </div>
              </CardContent>
            </Card>

            <div className="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
              <KpiCard title="Monto total 2026" value={formatCLP(totals.total2026)} subtitle="Base comparativa" icon={Wallet} />
              <KpiCard title="Monto total 2027" value={formatCLP(totals.total2027)} subtitle={datasetName} icon={BarChart3} trend={totals.variacionPct} />
              <KpiCard title="Proyectos 2027" value={formatNumber(totals.proyectos2027)} subtitle={`Variación: ${formatNumber(totals.variacionProyectos)}`} icon={Layers3} />
              <KpiCard title="Promedio por proyecto 2027" value={formatCLP(totals.promedio2027)} subtitle="Monto / cantidad de proyectos" icon={Building2} />
            </div>

            <div className="grid gap-6 xl:grid-cols-[1.35fr_0.9fr]">
              <Card className="rounded-3xl shadow-sm">
                <CardHeader>
                  <CardTitle>Comparativo presupuestario 2026 vs 2027 por Subdirección</CardTitle>
                </CardHeader>
                <CardContent className="h-[380px]">
                  <ResponsiveContainer width="100%" height="100%">
                    <BarChart data={bySubdireccion}>
                      <CartesianGrid strokeDasharray="3 3" />
                      <XAxis dataKey="name" />
                      <YAxis tickFormatter={(v) => `${Math.round(v / 1000000)}M`} />
                      <Tooltip formatter={(value) => formatCLP(value)} />
                      <Legend />
                      <Bar dataKey="monto2026" name="Monto 2026" radius={[8, 8, 0, 0]} />
                      <Bar dataKey="monto2027" name="Monto 2027" radius={[8, 8, 0, 0]} />
                    </BarChart>
                  </ResponsiveContainer>
                </CardContent>
              </Card>

              <Card className="rounded-3xl shadow-sm">
                <CardHeader>
                  <CardTitle>Participación 2027 por Financiamiento</CardTitle>
                </CardHeader>
                <CardContent className="h-[380px]">
                  <ResponsiveContainer width="100%" height="100%">
                    <PieChart>
                      <Pie data={byFinanciamiento} dataKey="monto2027" nameKey="name" innerRadius={70} outerRadius={120} paddingAngle={2}>
                        {byFinanciamiento.map((entry, index) => (
                          <Cell key={`cell-${index}`} fill={COLORS[index % COLORS.length]} />
                        ))}
                      </Pie>
                      <Tooltip formatter={(value) => formatCLP(value)} />
                      <Legend />
                    </PieChart>
                  </ResponsiveContainer>
                </CardContent>
              </Card>
            </div>

            <div className="grid gap-6 xl:grid-cols-2">
              <Card className="rounded-3xl shadow-sm">
                <CardHeader>
                  <CardTitle>Ranking de asignaciones con mayor monto 2027</CardTitle>
                </CardHeader>
                <CardContent className="h-[350px]">
                  <ResponsiveContainer width="100%" height="100%">
                    <BarChart layout="vertical" data={rankingMontos}>
                      <CartesianGrid strokeDasharray="3 3" />
                      <XAxis type="number" tickFormatter={(v) => `${Math.round(v / 1000000)}M`} />
                      <YAxis type="category" dataKey="name" width={140} />
                      <Tooltip formatter={(value) => formatCLP(value)} />
                      <Bar dataKey="monto2027" name="Monto 2027" radius={[0, 8, 8, 0]} />
                    </BarChart>
                  </ResponsiveContainer>
                </CardContent>
              </Card>

              <Card className="rounded-3xl shadow-sm">
                <CardHeader>
                  <CardTitle>Variación absoluta por asignación</CardTitle>
                </CardHeader>
                <CardContent className="h-[350px]">
                  <ResponsiveContainer width="100%" height="100%">
                    <BarChart data={rankingVariacion}>
                      <CartesianGrid strokeDasharray="3 3" />
                      <XAxis dataKey="name" hide />
                      <YAxis tickFormatter={(v) => `${Math.round(v / 1000000)}M`} />
                      <Tooltip formatter={(value) => formatCLP(value)} />
                      <Bar dataKey="variacionAbs" name="Variación" radius={[8, 8, 0, 0]} />
                    </BarChart>
                  </ResponsiveContainer>
                </CardContent>
              </Card>
            </div>

            <div className="grid gap-6 xl:grid-cols-[1fr_1fr]">
              <Card className="rounded-3xl shadow-sm">
                <CardHeader>
                  <CardTitle>Dispersión: monto 2027 vs proyectos 2027</CardTitle>
                </CardHeader>
                <CardContent className="h-[360px]">
                  <ResponsiveContainer width="100%" height="100%">
                    <ScatterChart>
                      <CartesianGrid strokeDasharray="3 3" />
                      <XAxis type="number" dataKey="proyectos2027" name="Proyectos 2027" />
                      <YAxis type="number" dataKey="monto2027" name="Monto 2027" tickFormatter={(v) => `${Math.round(v / 1000000)}M`} />
                      <Tooltip cursor={{ strokeDasharray: "3 3" }} formatter={(value, name) => name === "Monto 2027" ? formatCLP(value) : formatNumber(value)} />
                      <Scatter name="Asignaciones" data={filteredRows} />
                    </ScatterChart>
                  </ResponsiveContainer>
                </CardContent>
              </Card>

              <Card className="rounded-3xl shadow-sm">
                <CardHeader>
                  <CardTitle>Mapa de concentración por Programa (2027)</CardTitle>
                </CardHeader>
                <CardContent className="h-[360px]">
                  <ResponsiveContainer width="100%" height="100%">
                    <Treemap data={heatmapData} dataKey="size" stroke="#fff" fill="#1d4ed8" />
                  </ResponsiveContainer>
                </CardContent>
              </Card>
            </div>

            <div className="grid gap-6 xl:grid-cols-[1fr_1fr]">
              <Card className="rounded-3xl shadow-sm">
                <CardHeader>
                  <CardTitle>Hallazgos automáticos</CardTitle>
                </CardHeader>
                <CardContent className="space-y-3">
                  {insights.map((insight, index) => (
                    <div key={index} className="rounded-2xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-700">
                      {insight}
                    </div>
                  ))}
                </CardContent>
              </Card>

              <Card className="rounded-3xl shadow-sm">
                <CardHeader>
                  <CardTitle>Alertas de gestión</CardTitle>
                </CardHeader>
                <CardContent className="space-y-3 text-sm">
                  <div className="rounded-2xl border border-amber-200 bg-amber-50 p-4 text-amber-900">
                    <div className="mb-1 flex items-center gap-2 font-medium"><AlertTriangle className="h-4 w-4" /> Concentración presupuestaria</div>
                    El top 3 concentra {formatPct(totals.top3Share)} del presupuesto 2027. Sobre 60% conviene monitoreo reforzado.
                  </div>
                  <div className="rounded-2xl border border-blue-200 bg-blue-50 p-4 text-blue-900">
                    <div className="mb-1 font-medium">Outliers detectados</div>
                    {outliers.length > 0 ? `${outliers.length} registros superan el umbral estadístico esperado.` : "No se detectan outliers relevantes con los filtros actuales."}
                  </div>
                  <div className="rounded-2xl border border-rose-200 bg-rose-50 p-4 text-rose-900">
                    <div className="mb-1 font-medium">Categorías con caída</div>
                    {decrecimientos.length > 0 ? decrecimientos.map((d) => `${d.name} (${formatPct(d.variacionPct)})`).join(" · ") : "No hay disminuciones relevantes."}
                  </div>
                </CardContent>
              </Card>
            </div>

            <Card className="rounded-3xl shadow-sm">
              <CardHeader>
                <CardTitle>Resumen ejecutivo por categoría</CardTitle>
              </CardHeader>
              <CardContent>
                <div className="overflow-auto rounded-2xl border">
                  <Table>
                    <TableHeader>
                      <TableRow>
                        <TableHead>Subdirección</TableHead>
                        <TableHead className="text-right">Monto 2026</TableHead>
                        <TableHead className="text-right">Monto 2027</TableHead>
                        <TableHead className="text-right">Var. abs.</TableHead>
                        <TableHead className="text-right">Var. %</TableHead>
                        <TableHead className="text-right">Prom. proyecto 2027</TableHead>
                      </TableRow>
                    </TableHeader>
                    <TableBody>
                      {bySubdireccion.map((row) => (
                        <TableRow key={row.name}>
                          <TableCell className="font-medium">{row.name}</TableCell>
                          <TableCell className="text-right">{formatCLP(row.monto2026)}</TableCell>
                          <TableCell className="text-right">{formatCLP(row.monto2027)}</TableCell>
                          <TableCell className="text-right">{formatCLP(row.variacionAbs)}</TableCell>
                          <TableCell className="text-right">
                            <Badge variant="secondary" className="rounded-xl">{formatPct(row.variacionPct)}</Badge>
                          </TableCell>
                          <TableCell className="text-right">{formatCLP(row.montoPromedio2027)}</TableCell>
                        </TableRow>
                      ))}
                    </TableBody>
                  </Table>
                </div>
              </CardContent>
            </Card>
          </TabsContent>
        </Tabs>
      </div>
    </div>
  );
}
