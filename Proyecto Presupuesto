function formatCLP(value) {
  return new Intl.NumberFormat("es-CL", {
    style: "currency",
    currency: "CLP",
    maximumFractionDigits: 0,
  }).format(Number(value || 0));
}

function formatNumber(value) {
  return new Intl.NumberFormat("es-CL").format(Number(value || 0));
}

function formatPct(value) {
  const n = Number(value || 0);
  return `${n.toFixed(1)}%`;
}

function safeDiv(a, b) {
  if (!b) return 0;
  return a / b;
}

function sum(arr, key) {
  return arr.reduce((acc, item) => acc + Number(item[key] || 0), 0);
}

function groupByField(data, field) {
  const map = new Map();
  data.forEach((item) => {
    const key = item[field] || "Sin dato";
    const prev = map.get(key) || {
      name: key,
      monto2026: 0,
      monto2027: 0,
      proyectos2026: 0,
      proyectos2027: 0,
      vigente2027: 0,
      comprometido2027: 0,
      devengado2027: 0,
      pagado2027: 0,
      beneficiarios2027: 0,
      registros: 0,
    };
    prev.monto2026 += Number(item.monto2026 || 0);
    prev.monto2027 += Number(item.monto2027 || 0);
    prev.proyectos2026 += Number(item.proyectos2026 || 0);
    prev.proyectos2027 += Number(item.proyectos2027 || 0);
    prev.vigente2027 += Number(item.presupuestoVigente2027 || 0);
    prev.comprometido2027 += Number(item.presupuestoComprometido2027 || 0);
    prev.devengado2027 += Number(item.presupuestoDevengado2027 || 0);
    prev.pagado2027 += Number(item.presupuestoPagado2027 || 0);
    prev.beneficiarios2027 += Number(item.beneficiarios2027 || 0);
    prev.registros += 1;
    map.set(key, prev);
  });

  return Array.from(map.values()).map((row) => ({
    ...row,
    variacionAbs: row.monto2027 - row.monto2026,
    variacionPct: row.monto2026 ? ((row.monto2027 - row.monto2026) / row.monto2026) * 100 : 0,
    montoPromedio2026: safeDiv(row.monto2026, row.proyectos2026),
    montoPromedio2027: safeDiv(row.monto2027, row.proyectos2027),
    montoPorBeneficiario2027: safeDiv(row.monto2027, row.beneficiarios2027),
    ejecucionPct: row.vigente2027 ? (row.devengado2027 / row.vigente2027) * 100 : 0,
    pagoPct: row.vigente2027 ? (row.pagado2027 / row.vigente2027) * 100 : 0,
  }));
}

function calculateOutlierThreshold(data) {
  const values = data.map((d) => Number(d.monto2027 || 0)).sort((a, b) => a - b);
  if (values.length < 4) return Infinity;
  const q1 = values[Math.floor(values.length * 0.25)];
  const q3 = values[Math.floor(values.length * 0.75)];
  const iqr = q3 - q1;
  return q3 + iqr * 1.5;
}

function topShare(data) {
  const total = sum(data, "monto2027");
  const sorted = [...data].sort((a, b) => b.monto2027 - a.monto2027);
  const top3 = sorted.slice(0, 3).reduce((acc, item) => acc + item.monto2027, 0);
  return total ? (top3 / total) * 100 : 0;
}

function downloadCSV(rows) {
  const headers = [
    "Subdirección",
    "Asignación presupuestaria",
    "Subtítulo",
    "Programa Presupuestario",
    "Instrumento",
    "Financiamiento",
    "Cantidad de proyectos 2026",
    "Cantidad de proyectos 2027",
    "Monto 2026",
    "Monto 2027",
  ];
  const content = [
    headers.join(","),
    ...rows.map((r) => [
      r.subdireccion,
      r.asignacion,
      r.subtitulo,
      r.programa,
      r.instrumento,
      r.financiamiento,
      r.proyectos2026,
      r.proyectos2027,
      r.monto2026,
      r.monto2027,
    ].map((v) => `"${String(v ?? "").replaceAll('"', '""')}"`).join(",")),
  ].join("\n");

  const blob = new Blob([content], { type: "text/csv;charset=utf-8;" });
  const url = URL.createObjectURL(blob);
  const a = document.createElement("a");
  a.href = url;
  a.download = "presupuesto-ejecutivo.csv";
  a.click();
  URL.revokeObjectURL(url);
}

